generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STAFF
  ADMIN
}

enum PaymentMethod {
  CASH
  ONLINE
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum BookingPaymentStatus {
  PENDING
  PARTIAL
  COMPLETED
  REJECTED
}

enum MatchStatus {
  UNMATCHED
  MATCHED
  MANUAL
}

enum BookingAdjustmentType {
  EXTRA_CHARGE
  EXTRA_HOURS
  DISCOUNT
}

enum AuditAction {
  LOGIN
  LOGIN_FAILED
  LOGOUT
  PAYMENT_RECORDED
  PAYMENT_UPDATED
  PAYMENT_DELETED
  PAYMENT_VERIFIED
  PAYMENT_REJECTED
  PAYMENT_AUTO_VERIFIED
  BOOKING_EXTRA_ADDED
  BOOKING_EXTRA_UPDATED
  BOOKING_EXTRA_REMOVED
  BOOKING_EXTRA_HOURS_ADDED
  EMAIL_SYNC
  BOOKING_CANCELLED
  BOOKING_DELETED
  BANK_STATEMENT_UPLOADED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recordedPayments Payment[]       @relation("RecordedBy")
  bankStatements BankStatement[] @relation("UploadedBy")
  bookingAdjustments BookingAdjustment[] @relation("AddedBy")
  auditLogs          AuditLog[]          @relation("AuditActor")
}

model Booking {
  id              String               @id @default(cuid())
  externalId      String?              @unique
  customerName    String
  customerPhone   String?
  customerEmail   String?
  venueName       String?
  turfName        String?
  location        String?
  bookingDate     DateTime
  startTime       String?
  endTime         String?
  slotEndTime     String?
  totalAmount     Decimal              @db.Decimal(10, 2)
  slotPrice       Decimal?             @db.Decimal(10, 2)
  couponAmount    Decimal?             @db.Decimal(10, 2)
  paidOnKhelomore Boolean              @default(false)
  paymentStatus   BookingPaymentStatus @default(PENDING)
  emailMessageId  String?              @unique
  rawEmailSubject String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  payments Payment[]
  adjustments BookingAdjustment[]

  @@index([bookingDate])
}

model BookingAdjustment {
  id          String                @id @default(cuid())
  bookingId   String
  type        BookingAdjustmentType
  description String
  amount      Decimal               @db.Decimal(10, 2)
  hoursAdded  Decimal?              @db.Decimal(4, 2)
  addedById   String
  createdAt   DateTime              @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addedBy User    @relation("AddedBy", fields: [addedById], references: [id])

  @@index([bookingId])
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  userId     String?
  userEmail  String?
  userName   String?
  userRole   UserRole?
  entityType String?
  entityId   String?
  bookingId  String?
  summary    String
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  user User? @relation("AuditActor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userEmail])
  @@index([action])
  @@index([bookingId])
}

model Payment {
  id                  String             @id @default(cuid())
  bookingId           String
  amount              Decimal            @db.Decimal(10, 2)
  method              PaymentMethod
  proofImageUrl       String?
  extractedSenderName String?
  extractedAmount     Decimal?           @db.Decimal(10, 2)
  verificationStatus  VerificationStatus @default(PENDING)
  verifiedAt          DateTime?
  verifiedById        String?
  notes               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  booking            Booking            @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  recordedBy         User?              @relation("RecordedBy", fields: [recordedById], references: [id])
  recordedById       String?
  bankTransaction    BankTransaction?

  @@index([bookingId])
  @@index([verificationStatus])
}

model BankStatement {
  id           String   @id @default(cuid())
  fileName     String
  fileUrl      String
  statementDate DateTime?
  uploadedById String
  createdAt    DateTime @default(now())

  uploadedBy   User              @relation("UploadedBy", fields: [uploadedById], references: [id])
  transactions BankTransaction[]
}

model BankTransaction {
  id              String      @id @default(cuid())
  statementId     String
  transactionDate DateTime?
  description     String
  amount          Decimal     @db.Decimal(10, 2)
  senderName      String?
  matchStatus     MatchStatus @default(UNMATCHED)
  matchedPaymentId String?    @unique
  createdAt       DateTime    @default(now())

  statement      BankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)
  matchedPayment Payment?      @relation(fields: [matchedPaymentId], references: [id])

  @@index([statementId])
  @@index([matchStatus])
}

model EmailSyncLog {
  id           String   @id @default(cuid())
  syncedAt     DateTime @default(now())
  emailsFound  Int      @default(0)
  bookingsCreated Int   @default(0)
  errors       String?
}
