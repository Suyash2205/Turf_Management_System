# Database (Neon Postgres - free tier: https://neon.tech)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET="your-secret-here"

# Vercel Blob (for payment proof images & bank statements)
# Create at: https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=""

# Email sync (Gmail with App Password recommended)
EMAIL_IMAP_HOST="imap.gmail.com"
EMAIL_IMAP_PORT="993"
EMAIL_IMAP_USER="your-email@gmail.com"
EMAIL_IMAP_PASSWORD="your-app-password"

# Cron job secret (for automated email sync — used by Google Apps Script)
CRON_SECRET="your-cron-secret"

# Sync mode: "poll" = only check last 2 days (use with 1-min Apps Script trigger)
EMAIL_SYNC_MODE="poll"
EMAIL_SYNC_POLL_DAYS="2"

# Khelomore venue filter — only import bookings for YOUR venue (all turfs at that venue)
KHELOMORE_VENUE_NAME="Lush Sports"
# Optional: restrict to a single turf/court only (leave blank to import all turfs)
# KHELOMORE_TURF_NAME="Perth Turf"
