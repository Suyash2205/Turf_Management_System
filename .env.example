# Database (Prisma Postgres — use pooled URL for app, direct for migrations)
# For Vercel/serverless, keep connection_limit=1 on the pooled URL.
DATABASE_URL="postgresql://user:password@pooled.db.prisma.io:5432/postgres?sslmode=require&connection_limit=1"
DIRECT_URL="postgresql://user:password@db.prisma.io:5432/postgres?sslmode=require"

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET="your-secret-here"

# Vercel Blob (for payment proof images & bank statements)
# Create at: https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=""

# Email sync (Gmail with App Password recommended)
EMAIL_IMAP_HOST="imap.gmail.com"
EMAIL_IMAP_PORT="993"
EMAIL_IMAP_USER="your-email@gmail.com"
EMAIL_IMAP_PASSWORD="your-app-password"

# Cron job secret (for automated email sync — used by Google Apps Script)
CRON_SECRET="your-cron-secret"

# Sync mode: "poll" = only check last 2 days (use with 1-min Apps Script trigger)
EMAIL_SYNC_MODE="poll"
EMAIL_SYNC_POLL_DAYS="2"

# Google Sheets export (service account — share sheet with client_email as Editor)
GOOGLE_SHEETS_SPREADSHEET_ID=""
GOOGLE_SHEETS_CLIENT_EMAIL=""
GOOGLE_SHEETS_PRIVATE_KEY=""

# Seed user passwords (local/CI only — set in Vercel only when running seed:users)
SEED_PASSWORD_ADMIN=""
SEED_PASSWORD_STAFF=""
SEED_PASSWORD_HITESH=""
SEED_PASSWORD_SABA=""
SEED_PASSWORD_RUMANA=""
SEED_PASSWORD_SHANAWAZ=""
SEED_PASSWORD_YOGITA=""
SEED_PASSWORD_SUNIL=""
SEED_PASSWORD_SUYASH=""
SEED_PASSWORD_NITESH=""
SEED_PASSWORD_VIVEK=""

# Khelomore venue filter — only import bookings for YOUR venue (all turfs at that venue)
KHELOMORE_VENUE_NAME="Lush Sports"
# Optional: restrict to a single turf/court only (leave blank to import all turfs)
# KHELOMORE_TURF_NAME="Perth Turf"
